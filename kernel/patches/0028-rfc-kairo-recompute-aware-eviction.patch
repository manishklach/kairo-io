  */
@@ -737,4 +808,6 @@ static void blk_mq_rq_ctx_init(struct blk_mq_tags *tags,
 	rq->part = NULL;
 	seqcount_init(&rq->gstate_seq);
 	u64_stats_init(&rq->kairo_stats.syncp);
+	/* CONCEPTUAL-HOOK: kairo_eviction_class_from_request(rq)
