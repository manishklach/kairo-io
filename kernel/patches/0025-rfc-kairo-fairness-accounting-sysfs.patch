+static ssize_t deadline_kairo_fairness_enable_show(
+	struct elevator_queue *e, char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+	/* CONCEPTUAL-HOOK: Access per-device fairness state */
+	return sysfs_emit(page, "%d\n",
+		dd->kairo_fairness.enabled ? 1 : 0);
+}
+
+static ssize_t deadline_kairo_fairness_enable_store(
+	struct elevator_queue *e, const char *page, size_t count)
+{
+	struct deadline_data *dd = e->elevator_data;
+	int data, ret;
+
+	ret = kstrtoint(page, 0, &data);
+	if (ret < 0)
+		return ret;
+	if (data < 0 || data > 1)
+		return -EINVAL;
+	dd->kairo_fairness.enabled = !!data;
+	return count;
+}
+
