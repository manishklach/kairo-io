+/*
+ * Accounting: Counters are wired into Stage 12 fairness hooks.
+ *
+ * kairo_fairness_refill_if_needed():
+ *   fs->fairness_refills++
+ *
+ * kairo_fairness_allow_decode():
+ *   fs->protected_decode_dispatches++ when credit consumed
+ *   fs->fairness_session_throttles++ when throttled
+ *   entity->throttled_events++
+ *
+ * kairo_fairness_throttle_prefetch():
+ *   fs->prefetch_fairness_throttles++ when throttled
+ *
+ * kairo_fairness_demote_write():
+ *   entity->writes_demoted++
+ *   fs->write_fairness_demotions++
+ *
+ * kairo_fairness_account_dispatch():
+ *   fs->noisy_session_events++ when threshold crossed
+ *
+ * Each counter is an event observation, not a unique request count.
+ * A single request may trigger multiple counters if it passes through
+ * multiple fairness hooks.
+ */
 
+/* Extend deadline_attrs with fairness entries */
 static struct elv_fs_entry deadline_attrs[] = {
 	DD_ATTR(kairo_enable),
 	DD_ATTR(kairo_decode_budget),
