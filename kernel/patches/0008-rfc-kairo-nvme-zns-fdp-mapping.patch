+/*
+ * SECTION E: NVMe Kairo mapping placeholder.
+ *
+ * CONCEPTUAL-HOOK: This structure is a placeholder for NVMe-specific
+ * placement fields. No actual NVMe commands use this data yet; it
+ * exists to show where Streams/FDP/ZNS fields would be populated
+ * when hardware support is detected and wired.
+ *
+ * Compile risk: LOW. The struct references only basic integer types.
+ */
 struct nvme_kairo_mapping {
 	u16 streamid;
 	u16 phandle;

diff --git a/drivers/nvme/host/nvme.h b/drivers/nvme/host/nvme.h
index 2f3c2ad..8b9e7c1 100644
--- a/drivers/nvme/host/nvme.h
+++ b/drivers/nvme/host/nvme.h
@@ -XXX,6 +XXX,XXX @@
+/*
+ * SECTION F: NVMe backend capability detection.
+ *
+ * CONCEPTUAL-HOOK: Returns a kairo_backend_caps struct indicating
+ * which NVMe placement features the device supports. Currently all
+ * bits are hardcoded to false (no-op).
+ *
+ * When wired to real detection, this function should query:
+ *   streams: ctrl->nr_streams > 0
+ *   fdp:     ctrl->nr_ruhs > 0 (FDP RUH count from identify)
+ *   zns:     ns->head->ids or ns->head->features zoned bit
+ *
+ * Compile risk:
+ *   LOW as no-op (returns zeroed struct).
+ *   MEDIUM when wired — requires correct pointer chasing through
+ *   nvme_ctrl / nvme_ns and may need version-specific identify
+ *   command handling for FDP.
+ */
+static inline struct kairo_backend_caps
+nvme_kairo_get_backend_caps(struct request_queue *q)
+{
+	struct kairo_backend_caps caps = { false, false, false };
+	return caps;
+}
+
diff --git a/drivers/nvme/host/core.c b/drivers/nvme/host/core.c
index 6d201df..5cd9028 100644
--- a/drivers/nvme/host/core.c
+++ b/drivers/nvme/host/core.c
@@ -XXX,6 +XXX,XXX @@
+/*
+ * SECTION G: Backend hint preparation and application.
+ *
+ * CONCEPTUAL-HOOK: These functions translate Kairo placement metadata
+ * into backend placement hints, using the kairo_backend_caps
+ * abstraction to select the active backend feature.
+ *
+ * The prepare/apply split allows the hint to be prepared early in
+ * request setup and applied later when the NVMe command is being
+ * assembled.
+ *
+ * Compile risk: MEDIUM. The functions themselves are self-contained,
+ * but the call site insertion in nvme_setup_cmd() is version-sensitive.
+ *
+ * VERSION-SENSITIVE: Call site must be placed after nvme_setup_rw()
+ * succeeds and before command submission.
+ */
+static void nvme_kairo_prepare_backend_hint(struct request *rq)
+{
+	struct kairo_backend_caps caps;
+	struct kairo_backend_hint *hint = &rq->kairo_hints.placement.backend;
+
+	kairo_backend_hint_from_request(rq, hint);
+	caps = nvme_kairo_get_backend_caps(rq->q);
+	kairo_backend_hint_apply_caps(hint, &caps);
+}
+
+static void nvme_kairo_apply_backend_hint(struct request *rq)
+{
+	struct kairo_backend_hint *hint = &rq->kairo_hints.placement.backend;
+	/*
+	 * CONCEPTUAL-HOOK: no-op until NVMe backend feature is wired.
+	 *
+	 * When support is detected, this function would:
+	 * - set NVMe command stream_id (for Streams)
+	 * - set NVMe command FDP placement handle (for FDP)
+	 * - set NVMe command zone append/placement hint (for ZNS)
+	 *
+	 * Currently the hint is populated but not applied to hardware.
+	 */
+	(void)hint;
+}
+
+/*
+ * Existing mapping: legacy nvme_kairo_select_mapping remains as a
+ * simpler mapping path for backward compatibility.
+ */
 static void nvme_kairo_select_mapping(struct request *rq,
 				      struct nvme_kairo_mapping *map)
 {
@@ -XXX,6 +XXX,XXX @@
+	/*
+	 * RFC/POC: call into the new backend mapping layer.
+	 * The backend hint is prepared and stored in the request's
+	 * kairo_hints.placement.backend field, then applied (no-op).
+	 */
+	if (ctrl->nr_streams || ctrl->nr_ruhs) {
+		nvme_kairo_prepare_backend_hint(rq);
+		nvme_kairo_apply_backend_hint(rq);
+	}
+
 	if (ctrl->nr_streams || ctrl->nr_ruhs) {
 		struct nvme_kairo_mapping map;

 		nvme_kairo_select_mapping(rq, &map);
 		/*
 		 * RFC/POC only: if unsupported, this remains a no-op and the
		 * request proceeds through the normal generic NVMe path.
		 */
 	}

diff --git a/drivers/nvme/host/zns.c b/drivers/nvme/host/zns.c
index 4ca102f..ac77fe9 100644
--- a/drivers/nvme/host/zns.c
+++ b/drivers/nvme/host/zns.c
@@ -XXX,6 +XXX,XXX @@
+/*
+ * SECTION H: ZNS-aware Kairo zone reset candidate detection.
+ *
+ * CONCEPTUAL-HOOK: Returns true if this request is a good candidate
+ * for zone reset based on Kairo eviction and lifetime metadata.
+ *
+ * Compile risk: LOW. The function is a simple predicate on Kairo
+ * metadata fields. It compiles on any kernel version, though it
+ * remains dead code until a call site is wired in a ZNS zone
+ * management path.
+ */
 static bool nvme_kairo_zone_reset_candidate(struct request *rq)
 {
 	return rq->kairo_hints.io_class == KAIRO_IO_EVICT &&
 	       rq->kairo_hints.placement.lifetime_class == KAIRO_LIFE_SESSION;
 }
