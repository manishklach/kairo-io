From 8888888888880000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Kairo POC <kairo-poc@local>
Date: Sun, 21 Jun 2026 14:35:00 -0700
Subject: [RFC/POC PATCH 8/9] nvme: add Kairo generic backend mapping scaffold

Subsystem touched:
- `include/linux/blk_types.h`
- `include/linux/blk-mq.h`
- `block/blk-mq.c`
- `include/linux/nvme.h`
- `drivers/nvme/host/nvme.h`
- `drivers/nvme/host/core.c`
- `drivers/nvme/host/zns.c`

New Kairo concept:
- generic backend placement mapping layer that converts Stage 6
  placement/lifetime metadata into a neutral backend class
- `struct kairo_backend_caps` abstraction replacing per-feature
  detection helpers
- feature-detected NVMe hooks (Streams, FDP, ZNS) with safe no-op
  fallback via unified caps query
- separate mapping layer from physical command programming

Relation to AI KV-cache traffic:
- short-lived and session-scoped cache data maps naturally to
  KAIRO_BACKEND_SHORT_LIVED / KAIRO_BACKEND_SESSION_LOCAL
- model-scoped data maps to KAIRO_BACKEND_MODEL_LOCAL
- recomputable data maps to KAIRO_BACKEND_RECOMPUTABLE
- persistent data maps to KAIRO_BACKEND_PERSISTENT
- cache_pool_id and placement_group select placement pool/group
  within a class

Section layout:
  A  blk_types.h        enum kairo_backend_class, struct kairo_backend_hint, flags
  B  blk_types.h        struct kairo_backend_caps (capability abstraction)
  C  blk-mq.h           generic backend helpers (class_from_request, hint_from_request, ...)
  D  blk-mq.h           kairo_backend_hint_apply_caps (caps -> hint)
  E  include/linux/nvme.h  nvme_kairo_mapping (legacy placeholder)
  F  drivers/nvme/host/nvme.h  nvme_kairo_get_backend_caps (detection query)
  G  drivers/nvme/host/core.c  nvme_kairo_prepare/apply_backend_hint, call site
  H  drivers/nvme/host/zns.c   nvme_kairo_zone_reset_candidate

RFC/POC staging:
- backend class mapping is metadata-only for now
- NVMe hooks are detected and no-op unless backend support is wired
- no physical placement commands are issued by this patch

Still to validate:
- whether the generic backend class abstraction survives real NVMe
  device attachment with Streams/FDP/ZNS capabilities
- whether software-only backend classification provides measurable
  benefit before hardware mapping is wired
- whether the kairo_backend_caps abstraction is sufficient for all
  target NVMe backends (Streams, FDP, ZNS, endurance groups)

diff --git a/include/linux/blk_types.h b/include/linux/blk_types.h
index f190ccd..d20ef19 100644
--- a/include/linux/blk_types.h
+++ b/include/linux/blk_types.h
@@ -XXX,6 +XXX,XXX @@
+/*
+ * SECTION A: Backend class enum and placement hint structure.
+ *
+ * COMPILE-TARGET: These types add no external kernel dependencies and
+ * compile cleanly on any kernel version with the Kairo foundation
+ * stack applied.
+ */
+
+enum kairo_backend_class {
+	KAIRO_BACKEND_NONE = 0,
+	KAIRO_BACKEND_SHORT_LIVED,
+	KAIRO_BACKEND_SESSION_LOCAL,
+	KAIRO_BACKEND_MODEL_LOCAL,
+	KAIRO_BACKEND_RECOMPUTABLE,
+	KAIRO_BACKEND_PERSISTENT,
+};
+
+/*
+ * Generic backend placement hint.
+ *
+ * Converts Stage 6 placement/lifetime metadata into a neutral backend
+ * class that can later be mapped to NVMe Streams, FDP placement IDs,
+ * or ZNS zone hints when hardware support is detected.
+ *
+ * RFC/POC: this structure carries conceptual mapping fields.
+ * No physical NVMe commands are programmed from this data yet.
+ */
+struct kairo_backend_hint {
+	enum kairo_backend_class backend_class;
+	u32 stream_id;
+	u32 fdp_placement_id;
+	u32 zone_hint;
+	u32 placement_group;
+	u32 cache_pool_id;
+	u32 flags;
+};
+
+/* Backend hint flags */
+#define KAIRO_BACKEND_F_STREAMS_CAPABLE	BIT(0)
+#define KAIRO_BACKEND_F_FDP_CAPABLE	BIT(1)
+#define KAIRO_BACKEND_F_ZNS_CAPABLE	BIT(2)
+#define KAIRO_BACKEND_F_NOOP_FALLBACK	BIT(3)
+#define KAIRO_BACKEND_F_RECOMPUTABLE	BIT(4)
+
+/*
+ * SECTION B: Backend capability abstraction.
+ *
+ * COMPILE-TARGET: Simple POD struct with no external dependencies.
+ * Replaces per-feature _supported() helpers with a single query
+ * function that returns a caps bitmap.
+ */
+
+/*
+ * struct kairo_backend_caps - summary of device backend capabilities.
+ *
+ * Populated by nvme_kairo_get_backend_caps() (or equivalent for
+ * non-NVMe devices). Each boolean indicates whether the corresponding
+ * backend placement feature is available on the target device.
+ */
+struct kairo_backend_caps {
+	bool streams : 1;
+	bool fdp     : 1;
+	bool zns     : 1;
+};
+
  struct kairo_request_hints {
  	enum kairo_io_class io_class;
  	u64 kairo_deadline_ns;
  	u32 kairo_prefetch_distance;
  	struct kairo_placement_hint placement;
+	struct kairo_backend_hint backend;
  	u32 flags;
  };

diff --git a/include/linux/blk-mq.h b/include/linux/blk-mq.h
index 7b11be3..e4f2a1c 100644
--- a/include/linux/blk-mq.h
+++ b/include/linux/blk-mq.h
@@ -XXX,6 +XXX,XXX @@
+/*
+ * SECTION C: Generic backend mapping helpers.
+ *
+ * COMPILE-TARGET: These convert per-request placement/lifetime
+ * metadata into a neutral backend class and populate the backend
+ * hint structure. They reference only Kairo-introduced fields and
+ * compile cleanly with the full Kairo stack applied.
+ */
+
+static inline enum kairo_backend_class
+kairo_backend_class_from_request(struct request *rq)
+{
+	if (!rq->kairo_hints.placement.lifetime_class)
+		return KAIRO_BACKEND_NONE;
+
+	switch (rq->kairo_hints.placement.lifetime_class) {
+	case KAIRO_LIFE_SHORT:
+		return KAIRO_BACKEND_SHORT_LIVED;
+	case KAIRO_LIFE_SESSION:
+		return KAIRO_BACKEND_SESSION_LOCAL;
+	case KAIRO_LIFE_MODEL:
+		return KAIRO_BACKEND_MODEL_LOCAL;
+	case KAIRO_LIFE_PERSISTENT:
+		return KAIRO_BACKEND_PERSISTENT;
+	default:
+		return KAIRO_BACKEND_NONE;
+	}
+}
+
+static inline void
+kairo_backend_hint_from_request(struct request *rq,
+				struct kairo_backend_hint *hint)
+{
+	memset(hint, 0, sizeof(*hint));
+	hint->backend_class = kairo_backend_class_from_request(rq);
+	hint->placement_group = rq->kairo_hints.placement.placement_group;
+	hint->cache_pool_id = rq->kairo_hints.placement.cache_pool_id;
+
+	if (rq->kairo_hints.placement.recompute_ok) {
+		hint->flags |= KAIRO_BACKEND_F_RECOMPUTABLE;
+		if (hint->backend_class == KAIRO_BACKEND_NONE)
+			hint->backend_class = KAIRO_BACKEND_RECOMPUTABLE;
+	}
+}
+
+static inline bool
+kairo_backend_is_noop(const struct kairo_backend_hint *hint)
+{
+	return hint->flags & KAIRO_BACKEND_F_NOOP_FALLBACK;
+}
+
+static inline bool
+kairo_backend_is_recomputable(const struct kairo_backend_hint *hint)
+{
+	return hint->flags & KAIRO_BACKEND_F_RECOMPUTABLE;
+}
+
+/*
+ * SECTION D: Apply backend capabilities to a hint.
+ *
+ * COMPILE-TARGET: This helper takes a kairo_backend_caps struct and
+ * populates the corresponding hint fields. The caps struct is a simple
+ * POD; the actual caps query is device-specific (see Section F).
+ */
+
+static inline void
+kairo_backend_hint_apply_caps(struct kairo_backend_hint *hint,
+			      const struct kairo_backend_caps *caps)
+{
+	if (caps->streams) {
+		hint->stream_id = hint->placement_group
+				  ?: hint->cache_pool_id;
+		hint->flags |= KAIRO_BACKEND_F_STREAMS_CAPABLE;
+	} else if (caps->fdp) {
+		hint->fdp_placement_id = hint->cache_pool_id
+					 ?: hint->placement_group;
+		hint->flags |= KAIRO_BACKEND_F_FDP_CAPABLE;
+	} else if (caps->zns) {
+		hint->zone_hint = (u32)hint->backend_class;
+		hint->flags |= KAIRO_BACKEND_F_ZNS_CAPABLE;
+	} else {
+		hint->flags |= KAIRO_BACKEND_F_NOOP_FALLBACK;
+	}
+}
+
