+static void dd_kairo_account_nondecode_dispatch(struct deadline_data *dd,
+						struct request *rq,
+						enum dd_prio prio)
+{
+	dd->kairo_decode_budget_used = 0;
+	dd->kairo_prefetch_budget_used = 0;
+	dd->kairo_normal_dispatches++;
+	if (prio != DD_RT_PRIO && dd_queued(dd, DD_RT_PRIO) &&
+	    op_is_write(req_op(rq)))
+		dd->kairo_starvation_escapes++;
+	if (kairo_is_prefill_write(rq))
+		dd->kairo_prefill_dispatches++;
+	else if (kairo_is_evict(rq))
+		dd->kairo_evict_dispatches++;
+}
+
 static struct request *dd_kairo_dispatch_decode_request(struct deadline_data *dd,
 							unsigned long latest_start)
 {
@@ -1040,17 +1056,22 @@ static struct request *dd_dispatch_request(struct blk_mq_hw_ctx *hctx)
 		goto unlock;
 	}
 
 	rq = dd_dispatch_prio_aged_requests(dd, now);
-	if (rq)
+	if (rq) {
+		const u8 ioprio_class = dd_rq_ioclass(rq);
+
+		dd_kairo_account_nondecode_dispatch(dd, rq,
+			ioprio_class_to_prio[ioprio_class]);
 		goto unlock;
+	}
 
 	/*
 	 * Next, dispatch requests in priority order. Ignore lower priority
 	 * requests if any higher priority requests are pending.
 	 * Kairo decode and Kairo prefetch already had their opportunity above,
 	 * so keep the normal RT/BE/IDLE mq-deadline order for all remaining
 	 * traffic, including non-Kairo RT requests.
 	 */
 	for (prio = 0; prio <= DD_PRIO_MAX; prio++) {
 	rq = __dd_dispatch_request(dd, &dd->per_prio[prio], now);
 	if (rq || dd_queued(dd, prio))
 		break;
@@ -1058,16 +1079,7 @@ static struct request *dd_dispatch_request(struct blk_mq_hw_ctx *hctx)
 	}
 
 	if (rq) {
-		dd->kairo_decode_budget_used = 0;
-		dd->kairo_prefetch_budget_used = 0;
-		dd->kairo_normal_dispatches++;
-		if (prio != DD_RT_PRIO && dd_queued(dd, DD_RT_PRIO) &&
-		    op_is_write(req_op(rq)))
-			dd->kairo_starvation_escapes++;
-		if (kairo_is_prefill_write(rq))
-			dd->kairo_prefill_dispatches++;
-		else if (kairo_is_evict(rq))
-			dd->kairo_evict_dispatches++;
+		dd_kairo_account_nondecode_dispatch(dd, rq, prio);
 	}
 
 unlock:
@@ -1447,6 +1459,138 @@ SHOW_INT(deadline_fifo_batch_show, dd->fifo_batch);
 #undef SHOW_INT
