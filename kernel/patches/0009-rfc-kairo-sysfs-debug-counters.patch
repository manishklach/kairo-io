From 9999999999990000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Kairo POC <kairo-poc@local>
Date: Sun, 21 Jun 2026 15:25:00 -0700
Subject: [RFC/POC PATCH 9/9] block: align Kairo sysfs counters with foundation stack

Subsystem touched:
- `block/mq-deadline.c`

New Kairo concept:
- one aligned sysfs counter set for the foundation layer

Relation to AI KV-cache traffic:
- the benchmark must prove whether decode, prefetch, prefill, eviction, and
  hinted-request paths are active instead of treating all dispatches as generic

Temporary implementation:
- keep sysfs real first and leave debugfs as a later follow-up

Still to validate:
- whether any extra counters beyond the foundation set are worth keeping

diff --git a/block/mq-deadline.c b/block/mq-deadline.c
index 8b840aa..d91f31a 100644
--- a/block/mq-deadline.c
+++ b/block/mq-deadline.c
@@
 	u64 kairo_decode_dispatches;
+	u64 kairo_prefetch_dispatches;
+	u64 kairo_prefill_dispatches;
+	u64 kairo_evict_dispatches;
 	u64 kairo_normal_dispatches;
 	u64 kairo_starvation_escapes;
+	u64 kairo_hinted_requests;
+	u64 kairo_unhinted_requests;
 	unsigned int kairo_decode_budget_used;
@@
+static void dd_kairo_account_dispatch(struct deadline_data *dd, struct request *rq)
+{
+	switch (rq->kairo_hints.io_class) {
+	case KAIRO_IO_DECODE_READ:
+		dd->kairo_decode_dispatches++;
+		dd->kairo_hinted_requests++;
+		break;
+	case KAIRO_IO_PREFETCH_READ:
+		dd->kairo_prefetch_dispatches++;
+		dd->kairo_hinted_requests++;
+		break;
+	case KAIRO_IO_PREFILL_WRITE:
+		dd->kairo_prefill_dispatches++;
+		dd->kairo_hinted_requests++;
+		break;
+	case KAIRO_IO_EVICT:
+		dd->kairo_evict_dispatches++;
+		dd->kairo_hinted_requests++;
+		break;
+	case KAIRO_IO_NORMAL:
+		dd->kairo_normal_dispatches++;
+		dd->kairo_unhinted_requests++;
+		break;
+	default:
+		dd->kairo_unhinted_requests++;
+		break;
+	}
+}
@@
-	dd->kairo_decode_budget_used++;
-	dd->kairo_decode_dispatches++;
+	dd->kairo_decode_budget_used++;
+	dd_kairo_account_dispatch(dd, rq);
 	per_prio->latest_pos[DD_READ] = blk_rq_pos(rq);
 	per_prio->stats.dispatched++;
 	blk_req_zone_write_lock(rq);
@@
 	if (kairo_enable) {
 		if (rq && !kairo_is_decode_read(rq)) {
 			dd->kairo_decode_budget_used = 0;
-			dd->kairo_normal_dispatches++;
+			dd_kairo_account_dispatch(dd, rq);
 			if (rq_data_dir(rq) == WRITE && dd_queued(dd, DD_RT_PRIO))
 				dd->kairo_starvation_escapes++;
 		} else if (!rq) {
@@
+static ssize_t kairo_prefetch_dispatches_show(struct elevator_queue *e,
+					      char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n", dd->kairo_prefetch_dispatches);
+}
+
+static ssize_t kairo_prefill_dispatches_show(struct elevator_queue *e,
+					     char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n", dd->kairo_prefill_dispatches);
+}
+
+static ssize_t kairo_evict_dispatches_show(struct elevator_queue *e,
+					   char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n", dd->kairo_evict_dispatches);
+}
+
 static ssize_t kairo_normal_dispatches_show(struct elevator_queue *e,
 					    char *page)
 {
 	struct deadline_data *dd = e->elevator_data;
@@
 	return sysfs_emit(page, "%llu\n", dd->kairo_starvation_escapes);
 }
+
+static ssize_t kairo_hinted_requests_show(struct elevator_queue *e,
+					  char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n", dd->kairo_hinted_requests);
+}
+
+static ssize_t kairo_unhinted_requests_show(struct elevator_queue *e,
+					    char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n", dd->kairo_unhinted_requests);
+}
@@
+	__ATTR_RO(kairo_prefetch_dispatches),
+	__ATTR_RO(kairo_prefill_dispatches),
+	__ATTR_RO(kairo_evict_dispatches),
 	__ATTR_RO(kairo_normal_dispatches),
 	__ATTR_RO(kairo_starvation_escapes),
+	__ATTR_RO(kairo_hinted_requests),
+	__ATTR_RO(kairo_unhinted_requests),
 	__ATTR_NULL
 };
