diff --git a/block/mq-deadline.c b/block/mq-deadline.c
index 02a916b..df06aa7 100755
--- a/block/mq-deadline.c
+++ b/block/mq-deadline.c
@@ -37,6 +37,8 @@ static const int prio_aging_expire = 10 * HZ;
 static const int writes_starved = 2;    /* max times reads can starve a write */
 static const int fifo_batch = 16;       /* # of sequential requests treated as one
 				     by the above parameters. For throughput. */
+static int kairo_enable;                /* enable decode-first experimental path */
+static int kairo_decode_budget = 8;     /* consecutive decode dispatch budget */
 
 enum dd_data_dir {
 	DD_READ		= READ,
@@ -90,6 +92,10 @@ struct deadline_data {
 	enum dd_data_dir last_dir;
 	unsigned int batching;		/* number of sequential requests made */
 	unsigned int starved;		/* times reads have starved writes */
+	u64 kairo_decode_dispatches;
+	u64 kairo_normal_dispatches;
+	u64 kairo_starvation_escapes;
+	u32 kairo_decode_budget_used;
 
 	/*
 	 * settings that change how the i/o scheduler behaves
@@ -585,6 +591,32 @@ static struct request *dd_dispatch_prio_aged_requests(struct deadline_data *dd,
 	return NULL;
 }
 
+static struct request *dd_kairo_dispatch_decode_request(struct deadline_data *dd,
+							unsigned long now)
+{
+	struct request *rq;
+
+	if (!kairo_enable)
+		return NULL;
+
+	if (kairo_decode_budget <= 0)
+		return NULL;
+
+	if (dd->kairo_decode_budget_used >= kairo_decode_budget)
+		return NULL;
+
+	rq = __dd_dispatch_request(dd, &dd->per_prio[DD_RT_PRIO], now);
+	if (!rq)
+		return NULL;
+
+	if (!kairo_is_decode_read(rq))
+		return rq;
+
+	dd->kairo_decode_budget_used++;
+	dd->kairo_decode_dispatches++;
+	return rq;
+}
+
 /*
  * Called from blk_mq_run_hw_queue() -> __blk_mq_sched_dispatch_requests().
  *
@@ -601,6 +633,15 @@ static struct request *dd_dispatch_request(struct blk_mq_hw_ctx *hctx)
 	enum dd_prio prio;
 
 	spin_lock(&dd->lock);
+	rq = dd_kairo_dispatch_decode_request(dd, now);
+	if (rq) {
+		if (!kairo_is_decode_read(rq)) {
+			dd->kairo_decode_budget_used = 0;
+			dd->kairo_normal_dispatches++;
+		}
+		goto unlock;
+	}
+
 	rq = dd_dispatch_prio_aged_requests(dd, now);
 	if (rq)
 		goto unlock;
@@ -615,6 +656,16 @@ static struct request *dd_dispatch_request(struct blk_mq_hw_ctx *hctx)
 			break;
 	}
 
+	if (rq) {
+		if (kairo_enable && prio != DD_RT_PRIO &&
+		    dd_queued(dd, DD_RT_PRIO) && op_is_write(req_op(rq))) {
+			dd->kairo_starvation_escapes++;
+		}
+
+		dd->kairo_decode_budget_used = 0;
+		dd->kairo_normal_dispatches++;
+	}
+
 unlock:
 	spin_unlock(&dd->lock);
 
@@ -982,9 +1033,38 @@ SHOW_INT(deadline_writes_starved_show, dd->writes_starved);
 SHOW_INT(deadline_front_merges_show, dd->front_merges);
 SHOW_INT(deadline_async_depth_show, dd->async_depth);
 SHOW_INT(deadline_fifo_batch_show, dd->fifo_batch);
+SHOW_INT(deadline_kairo_enable_show, kairo_enable);
+SHOW_INT(deadline_kairo_decode_budget_show, kairo_decode_budget);
 #undef SHOW_INT
 #undef SHOW_JIFFIES
 
+static ssize_t deadline_kairo_decode_dispatches_show(struct elevator_queue *e,
+						      char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n",
+			  (unsigned long long)dd->kairo_decode_dispatches);
+}
+
+static ssize_t deadline_kairo_normal_dispatches_show(struct elevator_queue *e,
+						      char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n",
+			  (unsigned long long)dd->kairo_normal_dispatches);
+}
+
+static ssize_t deadline_kairo_starvation_escapes_show(struct elevator_queue *e,
+						      char *page)
+{
+	struct deadline_data *dd = e->elevator_data;
+
+	return sysfs_emit(page, "%llu\n",
+			  (unsigned long long)dd->kairo_starvation_escapes);
+}
+
 #define STORE_FUNCTION(__FUNC, __PTR, MIN, MAX, __CONV)			\
 static ssize_t __FUNC(struct elevator_queue *e, const char *page, size_t count)	\
 {									\
@@ -1012,12 +1092,16 @@ STORE_INT(deadline_writes_starved_store, &dd->writes_starved, INT_MIN, INT_MAX);
 STORE_INT(deadline_front_merges_store, &dd->front_merges, 0, 1);
 STORE_INT(deadline_async_depth_store, &dd->async_depth, 1, INT_MAX);
 STORE_INT(deadline_fifo_batch_store, &dd->fifo_batch, 0, INT_MAX);
+STORE_INT(deadline_kairo_enable_store, &kairo_enable, 0, 1);
+STORE_INT(deadline_kairo_decode_budget_store, &kairo_decode_budget, 1, INT_MAX);
 #undef STORE_FUNCTION
 #undef STORE_INT
 #undef STORE_JIFFIES
 
 #define DD_ATTR(name) \
 	__ATTR(name, 0644, deadline_##name##_show, deadline_##name##_store)
+#define DD_RO_ATTR(name) \
+	__ATTR(name, 0444, deadline_##name##_show, NULL)
 
 static struct elv_fs_entry deadline_attrs[] = {
 	DD_ATTR(read_expire),
@@ -1027,6 +1111,11 @@ static struct elv_fs_entry deadline_attrs[] = {
 	DD_ATTR(async_depth),
 	DD_ATTR(fifo_batch),
 	DD_ATTR(prio_aging_expire),
+	DD_ATTR(kairo_enable),
+	DD_ATTR(kairo_decode_budget),
+	DD_RO_ATTR(kairo_decode_dispatches),
+	DD_RO_ATTR(kairo_normal_dispatches),
+	DD_RO_ATTR(kairo_starvation_escapes),
 	__ATTR_NULL
 };
 
